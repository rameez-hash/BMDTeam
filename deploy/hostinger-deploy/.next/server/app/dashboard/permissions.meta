{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/permissions/layout,_N_T_/dashboard/permissions/page,_N_T_/dashboard/permissions"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/permissions/__PAGE__",
    "/dashboard/permissions",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}