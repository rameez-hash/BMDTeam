{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/announcements/layout,_N_T_/dashboard/announcements/page,_N_T_/dashboard/announcements"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/announcements/__PAGE__",
    "/dashboard/announcements",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}