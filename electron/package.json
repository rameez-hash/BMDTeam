{
  "name": "hrms-desktop",
  "version": "1.1.0",
  "description": "HRMS Desktop Application - Attendance Tracking",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win && node -e \"require('rcedit').rcedit('output/win-unpacked/BMD HRMS.exe',{icon:'assets/iconbmd.ico','version-string':{CompanyName:'BMD Digital',FileDescription:'BMD HRMS Desktop App',ProductName:'BMD HRMS',LegalCopyright:'Copyright 2026 BMD Digital'}})\" && npx electron-builder --win nsis --prepackaged output/win-unpacked",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "HRMS",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.bmddigital.hrms",
    "productName": "BMD HRMS",
    "copyright": "Copyright © 2026 BMD Digital",
    "directories": {
      "output": "output"
    },
    "extraResources": [
      {
        "from": "assets/iconbmd.ico",
        "to": "iconbmd.ico"
      },
      {
        "from": "assets/iconbmd.png",
        "to": "iconbmd.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/iconbmd.ico",
      "signAndEditExecutable": false,
      "publisherName": "BMD Digital"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/iconbmd.ico",
      "uninstallerIcon": "assets/iconbmd.ico",
      "installerHeaderIcon": "assets/iconbmd.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/iconbmd.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
