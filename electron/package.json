{
  "name": "hrms-desktop",
  "version": "1.9.1",
  "description": "HRMS Desktop Application - Attendance Tracking",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder && node -e \"const {rcedit}=require('rcedit');rcedit('output/win-unpacked/BMD HRMS.exe',{icon:'assets/iconbmd.ico','version-string':{CompanyName:'BMD Digital',FileDescription:'BMD HRMS Desktop App',ProductName:'BMD HRMS'}}).then(()=>console.log('Icon patched')).catch(e=>console.error(e))\"",
    "build:win": "electron-builder --win --publish=never && node -e \"require('rcedit').rcedit('output/win-unpacked/BMD HRMS.exe',{icon:'assets/iconbmd.ico','version-string':{CompanyName:'BMD Digital',FileDescription:'BMD HRMS Desktop App',ProductName:'BMD HRMS',LegalCopyright:'Copyright 2026 BMD Digital'}}).then(()=>console.log('Icon patched')).catch(e=>{console.error(e);process.exit(1)})\" && npx electron-builder --win nsis --prepackaged output/win-unpacked --publish=never",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "HRMS",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.bmddigital.hrms",
    "productName": "BMD HRMS",
    "copyright": "Copyright © 2026 BMD Digital",
    "directories": {
      "output": "output"
    },
    "extraResources": [
      {
        "from": "assets/iconbmd.ico",
        "to": "iconbmd.ico"
      },
      {
        "from": "assets/iconbmd.png",
        "to": "iconbmd.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/iconbmd.ico",
      "signAndEditExecutable": false,
      "artifactName": "BMD-HRMS-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/iconbmd.ico",
      "uninstallerIcon": "assets/iconbmd.ico",
      "installerHeaderIcon": "assets/iconbmd.ico",
      "include": "installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "assets/iconbmd.icns",
      "category": "public.app-category.business",
      "artifactName": "BMD-HRMS-${version}.${ext}",
      "identity": "-",
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "generic",
      "url": "https://hrms.bmdhouse.com/api/desktop-update"
    }
  }
}
